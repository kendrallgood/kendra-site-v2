source "https://rubygems.org"

# Jekyll itself
gem "jekyll", "~> 4.3"

# The theme, installed as a real dependency instead of fetched live
# at build time via remote_theme. This is the actual fix: the theme's
# files get resolved and locked once (via Gemfile.lock), not
# re-downloaded from GitHub on every single build.
gem "minimal-mistakes-jekyll", "~> 4.19"

# Plugins already used by the site (from _config.yml)
gem "jekyll-feed"
gem "jekyll-include-cache"

# Needed for local preview on newer Ruby versions
gem "webrick"
